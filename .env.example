# Copy to `.env` in the project root for local `npm start`.
# Values are the same as in Render → Environment (do not commit `.env`).

# Firebase Admin – full service account JSON on one line (from Firebase Console → Service accounts).
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Realtime Database URL (Firebase Console → Realtime Database).
FIREBASE_DATABASE_URL=https://YOUR-PROJECT-default-rtdb.europe-west1.firebasedatabase.app

# Resend – transactional email (password reset, sensor welcome).
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=noreply@aurahomesystems.eu

# Optional
# PORT=3000
# KEEP_ALIVE_URL=
