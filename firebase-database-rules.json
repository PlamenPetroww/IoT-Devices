{
  "rules": {
    "userEmailKeys": {
      "$authUid": {
        ".read": "auth != null && auth.uid === $authUid",
        ".write": "auth != null && auth.uid === $authUid"
      }
    },
    "users": {
      "$userKey": {
        ".read": "auth != null && (auth.uid === $userKey || root.child('userEmailKeys').child(auth.uid).val() === $userKey)",
        ".write": "auth != null && (auth.uid === $userKey || root.child('userEmailKeys').child(auth.uid).val() === $userKey)"
      }
    }
  }
}
