{
  "rules": {
    "userEmailKeys": {
      ".indexOn": ".value",
      "$authUid": {
        ".read": "auth != null && auth.uid === $authUid",
        ".write": "auth != null && auth.uid === $authUid"
      }
    },
    "users": {
      "$userKey": {
        ".read": "auth != null && (auth.uid === $userKey || root.child('userEmailKeys').child(auth.uid).val() === $userKey)",
        ".write": "auth != null && (auth.uid === $userKey || root.child('userEmailKeys').child(auth.uid).val() === $userKey)",
        "pendingAlarmEvents": {
          ".read": "auth != null && auth.token.nativeMonitorUserKey === $userKey"
        }
      }
    },
    "nativeDeviceTokens": {
      "$deviceId": {
        ".read": "auth != null",
        ".write": "$deviceId.matches(/^aura_[a-fA-F0-9]{32}$/) && newData.hasChildren(['token']) && newData.child('token').isString() && newData.child('token').val().length > 20"
      }
    }
  }
}
